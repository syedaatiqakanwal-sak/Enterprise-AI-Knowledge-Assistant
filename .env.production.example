# ==============================================================================
# PRODUCTION ENVIRONMENT EXAMPLE — copy to .env.production and fill secrets
# Never commit real production secrets.
# ==============================================================================
PROJECT_NAME=Enterprise AI Knowledge Assistant
PROJECT_VERSION=0.12.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true
METRICS_ENABLED=true
SECURITY_HEADERS_ENABLED=true
READY_REQUIRE_QDRANT=false

SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=https://app.example.com
PUBLIC_API_URL=https://app.example.com
BACKEND_CORS_ORIGINS=https://app.example.com

RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_WINDOW_SECONDS=60

POSTGRES_USER=eai_prod
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=enterprise_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://eai_prod:REPLACE_ME@postgres:5432/enterprise_ai

MONGO_INITDB_ROOT_USERNAME=eai_mongo
MONGO_INITDB_ROOT_PASSWORD=REPLACE_ME
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=enterprise_ai_logs
MONGO_URL=mongodb://eai_mongo:REPLACE_ME@mongodb:27017

QDRANT_HOST=qdrant
QDRANT_PORT=6333

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_ME
REDIS_URL=redis://:REPLACE_ME@redis:6379/0

IMAGE_REGISTRY=ghcr.io/your-org
IMAGE_TAG=0.12.0

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_ME

LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=REPLACE_ME
AGENT_PROVIDER=openai
ANALYTICS_ENABLED=true
TENANCY_ENABLED=true
SSO_ENABLED=false
SECRETS_DIR=/run/secrets

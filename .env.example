# ==============================================================================
# PROJECT CONFIGURATION
# ==============================================================================
PROJECT_NAME=Enterprise AI Knowledge Assistant
PROJECT_VERSION=0.12.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
LOG_JSON=false
METRICS_ENABLED=true
SECURITY_HEADERS_ENABLED=true
READY_REQUIRE_QDRANT=false
SECRETS_DIR=/run/secrets

# Swagger / OpenAPI contact
CONTACT_NAME=Enterprise AI Knowledge Assistant Team
CONTACT_EMAIL=support@example.com
CONTACT_URL=https://github.com/syedaatiqakanwal-sak/Enterprise-AI-Knowledge-Assistant

# ==============================================================================
# BACKEND CONFIGURATION
# ==============================================================================
BACKEND_PORT=8000
# REQUIRED: replace in production — never commit real secrets
SECRET_KEY=change_me_in_production_use_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1
FRONTEND_URL=http://127.0.0.1:3000
BACKEND_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8000,http://localhost:8000

RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_WINDOW_SECONDS=60

# Optional SMTP (when unset, emails are logged in development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_TLS=true

# Seed admin (optional — created on startup if both email and password are set)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FULL_NAME=System Administrator

# ==============================================================================
# DATABASE - POSTGRESQL
# ==============================================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin_password
POSTGRES_DB=enterprise_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://admin:admin_password@postgres:5432/enterprise_ai
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ==============================================================================
# NOSQL - MONGODB
# ==============================================================================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin_password
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=enterprise_ai_logs
MONGO_URL=mongodb://admin:admin_password@mongodb:27017
MONGO_MIN_POOL_SIZE=1
MONGO_MAX_POOL_SIZE=50

# ==============================================================================
# VECTOR DB - QDRANT
# ==============================================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ==============================================================================
# CACHE - REDIS
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ==============================================================================
# AI SERVICES (Optional — used by later modules)
# ==============================================================================
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Module 6–8 defaults for local/dev (use mock when GPU/models unavailable)
# LLM providers: mock | openai | gemini | ollama | azure_openai | anthropic
LLM_PROVIDER=mock
LLM_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120
OLLAMA_CONNECT_TIMEOUT=5
# Embeddings: mock | minilm | bge
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=all-MiniLM-L6-v2
MEETING_PROVIDER=mock
WHISPER_MODEL=large-v3
WHISPER_FALLBACK_MODEL=small
MEETING_AUTO_INDEX_RAG=true
MEETING_DIARIZATION_ENABLED=true
FFMPEG_PATH=ffmpeg

# Module 9 — Agent Platform
AGENT_ENABLED=true
AGENT_PROVIDER=mock
AGENT_MAX_TOOL_CALLS=8
AGENT_EMAIL_ENABLED=false
AGENT_EMAIL_REQUIRE_CONFIRMATION=true
AGENT_WEB_SEARCH_ENABLED=false
AGENT_SQL_READONLY=true

# Module 10 — Analytics
ANALYTICS_ENABLED=true
ANALYTICS_LOG_API_REQUESTS=true
ANALYTICS_ALERT_ERROR_RATE=0.05
ANALYTICS_ALERT_LLM_LATENCY_MS=5000

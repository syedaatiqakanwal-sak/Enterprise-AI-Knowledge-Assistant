# ==============================================================================
# PROJECT CONFIGURATION
# ==============================================================================
PROJECT_NAME=enterprise-ai-assistant
ENVIRONMENT=development

# ==============================================================================
# BACKEND CONFIGURATION
# ==============================================================================
BACKEND_PORT=8000
SECRET_KEY=change_me_in_production_secret_key_123456789
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==============================================================================
# DATABASE - POSTGRESQL
# ==============================================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin_password
POSTGRES_DB=enterprise_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==============================================================================
# NOSQL - MONGODB
# ==============================================================================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin_password
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=enterprise_ai_logs
MONGO_URL=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}

# ==============================================================================
# VECTOR DB - QDRANT
# ==============================================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ==============================================================================
# CACHE - REDIS
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ==============================================================================
# AI SERVICES (Optional/External)
# ==============================================================================
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
